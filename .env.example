# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Pinecone
PINECONE_API_KEY=...
PINECONE_INDEX=parking-chatbot
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Embeddings (local, free)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Dynamic data (SQLite)
DB_PATH=./data/dynamic/parking.db

# Retrieval
TOP_K=4

# SMTP (optional — for email notifications to admin)
# If not set, notifications are in-app only (visible in dashboard + CLI).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@skypark-central.example
# ADMIN_EMAIL=admin@skypark-central.example
